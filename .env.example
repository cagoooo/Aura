# =====================================================================
# 5W1H 靈感發射器 Pro — 環境變數範本
# 複製此檔案為 .env.local（或 .env），填入實際值。.env* 已在 .gitignore。
# =====================================================================

# --- Google Gemini API ---
# 取得：https://aistudio.google.com/apikey （免費層每分鐘 15 次、每日 1500 次）
GOOGLE_GENAI_API_KEY=

# --- Cloudflare Turnstile（防 Bot 打爆 Gemini quota）---
# 1. 註冊：https://dash.cloudflare.com/?to=/:account/turnstile （免費，不需信用卡）
# 2. Add site → Domain 填你的部署網域（cagoooo.github.io 或正式網域）
#    Widget Mode 選「Invisible」最不打擾使用者
# 3. 拿到 Site Key（公開、寫進 NEXT_PUBLIC_）+ Secret Key（私密、絕對不要 commit）
#
# 開發階段可留空，server-side 會自動跳過驗證。一旦填入 TURNSTILE_SECRET_KEY，
# 4 個 AI flow 都會強制驗證 token。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Firebase Web 設定（遷移到 GitHub Pages + Functions 後才需要）---
# 從 Firebase Console → 專案設定 → 一般 → 您的應用程式 → SDK 設定和配置 取得
NEXT_PUBLIC_FB_API_KEY=
NEXT_PUBLIC_FB_AUTH_DOMAIN=
NEXT_PUBLIC_FB_PROJECT_ID=
NEXT_PUBLIC_FB_APP_ID=
